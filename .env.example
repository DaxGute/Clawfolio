# Alpaca (portfolio ingestion / Clawfolio daily run)
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# OpenClaw (npm run openclaw:chat) uses ChatGPT/Codex OAuth only — not Platform API keys.
# Do not set OPENAI_API_KEY / OPENAI_BASE_URL / OPENAI_ORG_ID / OPENAI_PROJECT for OpenClaw.
# Auth: npm run openclaw -- models auth login --provider openai-codex
# Codex harness plugin (once): npm run openclaw -- plugins install @openclaw/codex
